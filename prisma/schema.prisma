// Skool Workshop planningsysteem
// Datamodel. Alle id's zijn UUID's, alles heeft createdAt en updatedAt.
// Soft delete via deletedAt op de entiteiten waar historie belangrijk is.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERBEHEERDER
  PLANNER
  FINANCIEEL
  DOCENT
  LEZER
}

enum TeacherStatus {
  UITGENODIGD
  REGISTRATIE_GESTART
  TER_BEOORDELING
  AANVULLING_NODIG
  GOEDGEKEURD
  GEBLOKKEERD
  INACTIEF
  AFGEWEZEN
}

enum DocStatus {
  NIET_AANGELEVERD
  AANGELEVERD
  IN_BEHANDELING
  GOEDGEKEURD
  AFGEKEURD
  AANVULLING_NODIG
  VERLOPEN
}

enum DocType {
  CONTRACT
  VOG
  IDENTITEITSBEWIJS
  RIJBEWIJS
  KVK
  BTW
  CERTIFICAAT
  OVERIG
}

/// Centrale doelgroeplijst. Overal dezelfde waarden, geen vrije tekst meer.
enum Doelgroep {
  PRIMAIR_ONDERWIJS
  VOORTGEZET_ONDERWIJS
  SPECIAAL_ONDERWIJS
  MBO
  HBO
  UNIVERSITEIT
  BUITENSCHOOLSE_OPVANG
  KINDEROPVANG
  BIBLIOTHEEK
  JEUGDINSTELLING
  ZORGINSTELLING
  GEMEENTE
  BEDRIJF
  PARTICULIER
  VOLWASSENEN
  SENIOREN
  OVERIG
}

/// Wat een workshopdocent met een workshop mag. Alleen een beheerder zet dit.
/// Hoe een workshopdocent naar een opdracht reist.
enum Vervoer {
  AUTO
  OV
  FIETS
  ANDERS
}

enum Bevoegdheid {
  ZELFSTANDIG
  ASSISTEREN
  NIET_INZETBAAR
}

enum ClientType {
  BASISSCHOOL
  VOORTGEZET_ONDERWIJS
  MBO
  HBO
  UNIVERSITEIT
  BSO
  BIBLIOTHEEK
  GEMEENTE
  BEDRIJF
  ZORGINSTELLING
  JEUGDINSTELLING
  PARTICULIER
  OVERIG
}

enum ProjectStatus {
  CONCEPT
  OPTIE
  BEVESTIGD
  PLANNING_GESTART
  GEDEELTELIJK_BEZET
  VOLLEDIG_BEZET
  UITGEVOERD
  GEANNULEERD
  FINANCIEEL_AFGEROND
  GEARCHIVEERD
}

enum SessionStatus {
  NIET_GEPUBLICEERD
  DOCENTEN_GEZOCHT
  AANMELDINGEN_ONTVANGEN
  GEDEELTELIJK_BEZET
  VOLLEDIG_BEZET
  GEANNULEERD
  UITGEVOERD
}

enum PositionRole {
  HOOFDDOCENT
  WORKSHOPDOCENT
  ASSISTENT
  RESERVE
  COORDINATOR
}

enum ApplicationStatus {
  UITGENODIGD
  BEKEKEN
  AANGEMELD
  IN_BEHANDELING
  TOEGEWEZEN
  AFGEWEZEN
  GEWEIGERD
  INGETROKKEN
  VERLOPEN
  GEANNULEERD
}

enum ApplicationKind {
  AANMELDING
  UITNODIGING
}

enum WorkRegStatus {
  CONCEPT
  INGEDIEND
  CONTROLE_NODIG
  GOEDGEKEURD
  AFGEKEURD
  AANVULLING_NODIG
  KLAAR_VOOR_BETALING
  BETAALD
}

enum Channel {
  APP
  EMAIL
  WHATSAPP
  PUSH
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          Role      @default(DOCENT)
  active        Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  inviteToken   String?   @unique
  inviteExpires DateTime?
  resetToken    String?   @unique
  resetExpires  DateTime?
  sessionEpoch  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  teacher       TeacherProfile?
  notifications Notification[]
  auditLogs     AuditLog[]
}

model TeacherProfile {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  voornaam     String
  tussenvoegsel String?
  achternaam   String
  telefoon     String?
  geboortedatum DateTime?
  noodcontact  String?
  noodcontactTel String?
  straat       String?
  huisnummer   String?
  toevoeging   String?
  postcode     String?
  plaats       String?
  land         String        @default("Nederland")
  lat          Float?
  lng          Float?

  samenwerking String?       // ZZP of FREELANCE, er is geen loondienst
  kvk          String?
  btwNummer    String?
  iban         String?
  rekeninghouder String?
  uurtarief    Decimal?      @db.Decimal(10, 2)
  tariefVanaf  DateTime?     // vanaf wanneer dit tarief geldt
  tariefNotitie String?      // interne afspraak, alleen voor beheerders
  tariefDoor   String?       // wie het tarief voor het laatst aanpaste
  tariefOp     DateTime?
  minDagtarief Decimal?      @db.Decimal(10, 2)
  kmVergoeding Decimal?      @db.Decimal(10, 2)
  maxReisAfstand Int?
  regios       String[]      @default([])
  eigenVervoer Boolean       @default(false)
  standaardVervoer Vervoer?  // waarmee hij meestal reist
  rijbewijs    Boolean       @default(false)
  ovMogelijk   Boolean       @default(true)
  talen        String[]      @default([])
  doelgroepen  Doelgroep[]   @default([])
  interneNotitie String?

  status       TeacherStatus @default(UITGENODIGD)
  goedgekeurdOp DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  skills       TeacherWorkshopSkill[]
  documents    TeacherDocument[]
  tariefHistorie TariefHistorie[]
  availability Availability[]
  applications Application[]
  assignments  Assignment[]
  workRegs     WorkRegistration[]
  slots        EnrollmentSlot[]

  @@index([status])
  @@index([achternaam])
}

model TeacherWorkshopSkill {
  id         String         @id @default(uuid())
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  workshopId String
  workshop   Workshop       @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  bevoegdheid Bevoegdheid   @default(ZELFSTANDIG) // alleen een beheerder zet dit
  gezetDoor  String?
  gezetOp    DateTime?
  createdAt  DateTime       @default(now())

  @@unique([teacherId, workshopId])
}

model TeacherDocument {
  id          String    @id @default(uuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  type        DocType
  bestandsnaam String?
  opslagSleutel String?
  uploadedAt  DateTime?
  vervaldatum DateTime?
  status      DocStatus @default(NIET_AANGELEVERD)
  verplicht   Boolean   @default(false)
  gecontroleerdDoor String?
  gecontroleerdOp DateTime?
  opmerking   String?
  versie      Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teacherId, type])
}

model Availability {
  id        String         @id @default(uuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  weekdag   Int?           // 1 = maandag t/m 7 = zondag, voor terugkerende beschikbaarheid
  datum     DateTime?      // specifieke datum
  dagdeel   String         @default("HELE_DAG") // OCHTEND, MIDDAG, AVOND, HELE_DAG
  beschikbaar Boolean      @default(true)
  notitie   String?
  createdAt DateTime       @default(now())

  @@index([teacherId, datum])
}

model WorkshopCategory {
  id        String     @id @default(uuid())
  naam      String     @unique
  kleur     String     @default("#f47c20")
  volgorde  Int        @default(0)
  workshops Workshop[]
}

model Workshop {
  id            String   @id @default(uuid())
  naam          String
  categoryId    String
  category      WorkshopCategory @relation(fields: [categoryId], references: [id])
  korteOmschrijving String?
  omschrijving  String?
  standaardDuur Int      @default(60) // minuten
  maxGroep      Int      @default(30)
  verkoopprijs  Decimal? @db.Decimal(10, 2) // wat de klant betaalt voor 60 minuten
  standaardVergoeding Decimal @default(0) @db.Decimal(10, 2)
  minVergoeding Decimal  @default(0) @db.Decimal(10, 2)
  voorbereidingstijd Int @default(30)
  materialen    String?
  materialenDoor String? @default("Skool Workshop")
  klantBenodigdheden String? // tekst voor de bevestigingsmail: wat de opdrachtgever regelt
  voorbeeldLink String?      // link naar een voorbeeldfoto van de opstelling
  afbeeldingUrl String?      // pad in de opslag van de app, of de bron als fallback
  afbeeldingAlt String?      // alt-tekst bij de foto
  bronPaginaUrl String?      // workshoppagina op skoolworkshop.nl
  bronAfbeeldingUrl String?  // oorspronkelijke afbeeldings-URL
  afbeeldingGesyncedOp DateTime?
  afbeeldingControle Boolean @default(false) // true als de koppeling onzeker is
  siteSlug      String?      // slug op skoolworkshop.nl
  locatieEisen  String?
  doelgroepen   Doelgroep[] @default([])
  minLeeftijd   Int?
  maxLeeftijd   Int?
  vereisteDocumenten DocType[] @default([])
  docentenPerGroep Int   @default(1)
  actief        Boolean  @default(true)
  interneInstructie String?
  docentInstructie String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  skills   TeacherWorkshopSkill[]
  sessions WorkshopSession[]
  slots    EnrollmentSlot[]
  afbeelding WorkshopAfbeelding?

  @@index([actief])
}

model Client {
  id          String     @id @default(uuid())
  klantnummer String     @unique
  naam        String
  type        ClientType @default(BASISSCHOOL)
  doelgroepen Doelgroep[] @default([])
  doelgroepToelichting String? // alleen invullen bij OVERIG
  cjpNummer   String?   // Cultuurkaart / CJP schoolnummer, alleen bij onderwijsklanten
  factuurEmail String?
  factuurAdres String?
  btwNummer   String?
  betaaltermijn Int      @default(30)
  notitie     String?
  tags        String[]   @default([])
  actief      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  locations ClientLocation[]
  contacts  ClientContact[]
  projects  Project[]

  @@index([naam])
}

model ClientLocation {
  id         String  @id @default(uuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  naam       String
  straat     String?
  huisnummer String?
  postcode   String?
  plaats     String
  land       String  @default("Nederland")
  lat        Float?
  lng        Float?
  route      String?
  parkeren   String?
  laadLossen String?
  toegankelijkheid String?
  verdieping String?
  lift       Boolean @default(false)
  materialenAanwezig String?
  notitie    String?
  createdAt  DateTime @default(now())

  sessions WorkshopSession[]
  projects Project[]
}

model ClientContact {
  id         String  @id @default(uuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  naam       String
  functie    String?
  telefoon   String?
  mobiel     String?
  email      String?
  voorkeur   String? @default("EMAIL")
  primair    Boolean @default(false)
  opDeDag    Boolean @default(false)
  financieel Boolean @default(false)
  notitie    String?
  createdAt  DateTime @default(now())

  sessions WorkshopSession[]
}

model Project {
  id           String        @id @default(uuid())
  ordernummer  String        @unique
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  locationId   String?
  location     ClientLocation? @relation(fields: [locationId], references: [id])
  naam         String
  status       ProjectStatus @default(CONCEPT)
  startDatum   DateTime?
  eindDatum    DateTime?
  notitie      String?
  interneNotitie String?
  aantalPersonenTekst String? // vrije tekst voor de bevestiging, bijv. "Maximaal 25 per workshop"
  omzet        Decimal       @default(0) @db.Decimal(10, 2)
  materiaalkosten Decimal    @default(0) @db.Decimal(10, 2)
  facturatieStatus String    @default("NOG_NIET")
  createdById  String?
  updatedById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  sessions WorkshopSession[]
  enrollment Enrollment?

  @@index([status])
}

model WorkshopSession {
  id           String        @id @default(uuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workshopId   String
  workshop     Workshop      @relation(fields: [workshopId], references: [id])
  locationId   String?
  location     ClientLocation? @relation(fields: [locationId], references: [id])
  contactId    String?
  contact      ClientContact? @relation(fields: [contactId], references: [id])

  datum        DateTime
  startTijd    String        // "09:00"
  eindTijd     String        // "12:30"
  aanwezigVanaf String?
  afbouwTot    String?       // eindtijd afbouw en vertrek
  deelnemers   Int           @default(0)
  leeftijd     String?
  doelgroep    Doelgroep?
  doelgroepToelichting String?
  aantalRondes Int           @default(1)
  tijdPerRonde Int           @default(60)
  ruimte       String?
  kleding      String?
  benodigdheden String?
  bijzonderheden String?
  veiligheid   String?
  telefoonOpDeDag String?
  vergoeding   Decimal       @default(0) @db.Decimal(10, 2)
  reiskosten   String?       @default("Kilometervergoeding")
  status       SessionStatus @default(NIET_GEPUBLICEERD)
  publicatieDatum DateTime?
  aanmeldDeadline DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  rounds    WorkshopRound[]
  positions StaffingPosition[]

  @@index([datum])
  @@index([status])
}

model WorkshopRound {
  id        String          @id @default(uuid())
  sessionId String
  session   WorkshopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nummer    Int
  startTijd String
  eindTijd  String
  groep     String?
  afdeling  String?         // bijvoorbeeld 4VWO of 4HAVO, voor een eigen tijdschema
  aantalGroepen Int         @default(1) // parallelle groepen van deze workshop in deze ronde
  deelnemers Int            @default(0)

  @@unique([sessionId, nummer])
}

model StaffingPosition {
  id          String          @id @default(uuid())
  sessionId   String
  session     WorkshopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rol         PositionRole    @default(WORKSHOPDOCENT)
  aantal      Int             @default(1)
  vergoeding  Decimal         @default(0) @db.Decimal(10, 2)
  vereisteDocumenten DocType[] @default([])
  gepubliceerd Boolean        @default(false)
  gesloten    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  applications Application[]
  assignments  Assignment[]
}

model Application {
  id          String            @id @default(uuid())
  positionId  String
  position    StaffingPosition  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     TeacherProfile    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  soort       ApplicationKind   @default(AANMELDING)
  status      ApplicationStatus @default(AANGEMELD)
  motivatie   String?
  interneBeoordeling String?
  reactieDeadline DateTime?
  bekekenOp   DateTime?
  gereageerdOp DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([positionId, teacherId])
  @@index([status])
}

model Assignment {
  id         String           @id @default(uuid())
  positionId String
  position   StaffingPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    TeacherProfile   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  uitgevallen Boolean         @default(false)
  toegewezenDoor String?
  toegewezenOp DateTime        @default(now())
  vervangerVoor String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  workReg WorkRegistration?

  @@unique([positionId, teacherId])
}

model WorkRegistration {
  id           String        @id @default(uuid())
  assignmentId String        @unique
  assignment   Assignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  startTijd    String?
  eindTijd     String?
  uren         Decimal       @default(0) @db.Decimal(6, 2)
  vervoer      Vervoer       @default(AUTO)
  kilometers   Int           @default(0)
  ovKosten     Decimal       @default(0) @db.Decimal(10, 2)
  parkeerkosten Decimal      @default(0) @db.Decimal(10, 2)
  overigeKosten Decimal      @default(0) @db.Decimal(10, 2)
  bonUrl       String?
  opmerking    String?
  incident     String?
  workshopVergoeding Decimal @default(0) @db.Decimal(10, 2)
  kmVergoeding Decimal       @default(0) @db.Decimal(10, 2)
  totaal       Decimal       @default(0) @db.Decimal(10, 2)
  status       WorkRegStatus @default(CONCEPT)
  correctieReden String?
  goedgekeurdDoor String?
  goedgekeurdOp DateTime?
  betaaldOp    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titel     String
  tekst     String
  link      String?
  gelezen   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, gelezen])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  sleutel   String   @unique
  kanaal    Channel
  onderwerp String?
  inhoud    String
  actief    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model MessageLog {
  id           String   @id @default(uuid())
  kanaal       Channel
  ontvanger    String
  sleutel      String
  onderwerp    String?
  inhoud       String
  status       String   @default("VERZONDEN") // VERZONDEN, MISLUKT, DEV
  fout         String?
  idempotencyKey String? @unique
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  actie     String
  entiteit  String
  entiteitId String?
  oud       String?
  nieuw     String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entiteit, entiteitId])
  @@index([createdAt])
}

// ==========================================================================
// Module B: inschrijfsysteem
// Leerlingen kiezen zelf hun workshops. Geen account, alleen een toegangscode.
// ==========================================================================

enum EnrollmentStatus {
  CONCEPT       // beheerder is aan het opzetten
  OPEN          // leerlingen kunnen inschrijven
  GESLOTEN      // sluitingsdatum voorbij of handmatig dicht
  DEFINITIEF    // indeling vastgezet, lijsten gegenereerd
}

enum EnrollmentMode {
  DIRECTE_KEUZE // leerling kiest per ronde meteen een workshop
  VOORKEUREN    // leerling geeft voorkeuren op, systeem verdeelt daarna
  KLASSIKAAL    // hele klassen rouleren, leerling kiest niets
}

enum CodeScope {
  EVENEMENT     // één code voor de hele school
  KLAS          // één code per klas
  LEERLING      // unieke code per leerling
}

// Een inschrijving hangt aan een project van het type cultuurdag of projectdag.
model Enrollment {
  id            String           @id @default(uuid())
  projectId     String           @unique
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titel         String
  status        EnrollmentStatus @default(CONCEPT)
  modus         EnrollmentMode   @default(DIRECTE_KEUZE)
  codeScope     CodeScope        @default(KLAS)

  keuzesPerRonde Int             @default(1)
  herhalingToegestaan Boolean     @default(false)
  wijzigenToegestaan  Boolean     @default(true)
  sluitingsdatum DateTime?
  voorkeurenAantal Int            @default(3)

  welkomtekst   String?
  toonVrijePlekken Boolean        @default(true)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  rondes        EnrollmentRound[]
  deelnemers    Participant[]
  codes         AccessCode[]

  @@index([status])
}

// Een ronde binnen een inschrijving, bijvoorbeeld ronde 1 van 09:00 tot 10:15.
model EnrollmentRound {
  id           String      @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  nummer       Int
  naam         String?
  startTijd    String
  eindTijd     String

  slots        EnrollmentSlot[]

  @@unique([enrollmentId, nummer])
}

// Eén workshop in één ronde, met capaciteit, ruimte en docent.
model EnrollmentSlot {
  id          String          @id @default(uuid())
  roundId     String
  round       EnrollmentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  workshopId  String
  workshop    Workshop        @relation(fields: [workshopId], references: [id])
  teacherId   String?
  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id])
  ruimte      String?
  capaciteit  Int             @default(25)
  minDeelnemers Int           @default(0)
  notitie     String?
  createdAt   DateTime        @default(now())

  keuzes      Choice[]
  voorkeuren  Preference[]

  @@unique([roundId, workshopId, ruimte])
  @@index([roundId])
}

// Een leerling. Geen account, hoort bij precies één inschrijving.
model Participant {
  id           String     @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  voornaam     String
  achternaam   String?
  klas         String
  email        String?
  extern       String?    // leerlingnummer uit het systeem van de school
  ingeschrevenOp DateTime?
  createdAt    DateTime   @default(now())

  keuzes       Choice[]
  voorkeuren   Preference[]
  codes        AccessCode[]

  @@index([enrollmentId, klas])
}

// 
// * De definitieve keuze van een leerling voor één ronde.
// * De unieke sleutel op participantId plus roundId zorgt ervoor dat een leerling
// * nooit twee workshops in dezelfde ronde kan hebben.
model Choice {
  id            String         @id @default(uuid())
  participantId String
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slotId        String
  slot          EnrollmentSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  roundId       String
  automatisch   Boolean        @default(false)
  aanwezig      Boolean?
  gescandOp     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([participantId, roundId])
  @@index([slotId])
}

// Een voorkeur in de voorkeurenmodus. Volgorde 1 is de eerste keuze.
model Preference {
  id            String         @id @default(uuid())
  participantId String
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slotId        String
  slot          EnrollmentSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  roundId       String
  volgorde      Int
  createdAt     DateTime       @default(now())

  @@unique([participantId, roundId, volgorde])
  @@index([slotId])
}

// Toegangscode voor leerlingen of voor de contactpersoon van de school.
model AccessCode {
  id            String       @id @default(uuid())
  enrollmentId  String
  enrollment    Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  code          String       @unique
  scope         CodeScope
  klas          String?
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: Cascade)
  schoolPortaal Boolean      @default(false)
  gebruikt      Int          @default(0)
  laatstGebruikt DateTime?
  actief        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  @@index([enrollmentId])
}

/// Vrije instellingen van het systeem, bijvoorbeeld de tarieven.
model Instelling {
  sleutel   String   @id
  waarde    String
  updatedAt DateTime @updatedAt
}

/// Historie van tariefafspraken per workshopdocent.
model TariefHistorie {
  id         String         @id @default(uuid())
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  veld       String         // uurtarief, minDagtarief of kmVergoeding
  oudeWaarde String?
  nieuweWaarde String?
  reden      String?
  doorUserId String?
  createdAt  DateTime       @default(now())

  @@index([teacherId, createdAt])
}

/// De opgeslagen foto van een workshop. We bewaren de bytes zelf,
/// zodat we niet permanent naar de website hoeven te hotlinken.
model WorkshopAfbeelding {
  id         String   @id @default(uuid())
  workshopId String   @unique
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  data       Bytes
  mimeType   String
  bytes      Int
  hash       String   // om dubbele downloads te herkennen
  bronUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hash])
}
